{
  "expo": {
    "name": "Folio",
    "slug": "folio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "folio",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1DB954"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.folio.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Folio needs camera access to scan coupons.",
        "NSPhotoLibraryUsageDescription": "Folio needs photo access to import coupon images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1DB954",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.folio.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Folio needs photo access to import coupon images.",
          "cameraPermission": "Folio needs camera access to scan coupons."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Folio needs camera access to scan coupons and barcodes."
        }
      ],
      "expo-notifications",
      "@react-native-community/datetimepicker"
    ]
  }
}
